# .env.example
# ------------
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the real `.env` file to version control.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your tokens


# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# Your Telegram Bot token from @BotFather.
BOT_TOKEN=your-telegram-bot-token-here


# ---------------------------------------------------------------------------
# AI Provider
# ---------------------------------------------------------------------------

# Which AI backend to use.
# Options: "openai" | "groq"
# Default: openai
AI_PROVIDER=openai

# Your API key. For OpenAI: starts with "sk-...".
# For Groq: get one free at https://console.groq.com
OPENAI_API_KEY=your-api-key-here

# (Optional) Override the model. Leave blank to use the provider default.
# OpenAI default : gpt-4o-mini
# Groq default   : llama3-70b-8192
AI_MODEL=

# (Optional) Custom base URL for OpenAI-compatible providers.
# Leave blank for standard OpenAI usage.
# For Groq: https://api.groq.com/openai/v1
AI_BASE_URL=


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Python logging level. Options: DEBUG | INFO | WARNING | ERROR
# Default: INFO
LOG_LEVEL=INFO
